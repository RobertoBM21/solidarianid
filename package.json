{
  "name": "solidarianid",
  "version": "0.0.1",
  "description": "",
  "author": "MISUM 2025 Grupo 2",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nx build",
    "build:all": "npm run build:core && npm run build:gateway && npm run build:admin && npm run build:front",
    "build:core": "nx build core",
    "build:gateway": "nx build gateway",
    "build:admin": "nx build admin && npm run build:css:admin && npm run build:css:admin-reports",
    "build:front": "nx build front",
    "build:css:admin": "postcss apps/admin/assets/main.css -o apps/admin/src/public/main.css",
    "build:css:admin-reports": "sass apps/admin/assets/reports.sass apps/admin/src/public/reports.css --no-source-map",
    "watch:css:admin": "postcss apps/admin/assets/main.css -o apps/admin/src/public/main.css --watch",
    "watch:css:admin-reports": "sass apps/admin/assets/reports.sass:apps/admin/src/public/reports.css --watch",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:dev:admin": "concurrently \"npm run watch:css:admin\" \"npm run watch:css:admin-reports\" \"nx serve admin\"",
    "start:dev:core": "nx serve core",
    "start:dev:gateway": "nx serve gateway",
    "start:dev:front": "nx start front --port 3080",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=test jest --coverage",
    "test:watch": "cross-env NODE_ENV=test jest --coverage --watch",
    "test:debug": "cross-env NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npm run test:e2e:admin && npm run test:e2e:core && npm run test:e2e:gateway",
    "test:e2e:admin": "cross-env NODE_ENV=test jest --config ./apps/admin/test/jest-e2e.config.js --runInBand",
    "test:e2e:core": "cross-env NODE_ENV=test jest --config ./apps/core/test/jest-e2e.config.js --runInBand",
    "test:e2e:gateway": "cross-env NODE_ENV=test jest --config ./apps/gateway/test/jest-e2e.config.js --runInBand",
    "test:mvc:admin": "cross-env NODE_ENV=test jest --config ./apps/admin/test/jest-mvc.config.js",
    "cy:open": "cypress open",
    "test:cypress": "cypress run",
    "test:mutation": "stryker run",
    "proto:gen": "npx protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./libs/shared/src/infrastructure/grpc/stubs --ts_proto_opt=nestJs=true -I=./grpc/protos ./grpc/protos/*.proto"
  },
  "dependencies": {
    "@apollo/client": "^4.1.7",
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@keyv/redis": "^5.1.5",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",

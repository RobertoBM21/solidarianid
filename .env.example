DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD_FILE=secrets/core_password.txt
DB_NAME=solidariandb

NATS_URL=nats://127.0.0.1:4222

CORE_GRPC_URL=localhost:5002
IDENTITY_GRPC_URL=localhost:5003

# core app
REDIS_URL=redis://127.0.0.1:6379
KURRENTDB_URL=kurrentdb://localhost:2113?tls=false
STRIPE_SK=not-valid
STRIPE_PAYMENT_SUCCESS_URL=http://localhost:3080/donations/complete?checkoutSessionId={CHECKOUT_SESSION_ID}

# admin app
SESSION_SECRET_FILE=secrets/admin_session_secret.txt

# gateway app
CORS_ORIGIN=*
JWT_SECRET_FILE=secrets/jwt_secret.txt
JWT_EXPIRATION=7d
GOOGLE_CLIENT_ID=my-google-client-id
GOOGLE_CLIENT_SECRET=my-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3010/auth/google/callback
CORE_URL=http://localhost:3000
IDENTITY_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3080

# front app
NEXTAUTH_URL=http://localhost:3080
NEXTAUTH_SECRET=my-nextauth-secret
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3010

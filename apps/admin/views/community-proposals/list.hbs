{{addLib 'axios'}}
{{addJs '/proposals.js'}}

<div class='w-full max-w-5xl mx-auto flex flex-col h-full'>
  <div class='flex justify-between items-center mb-4'>
    <h2 class='text-xl font-bold'>Validaciones pendientes</h2>
  </div>

  <div
    class='card bg-base-100 shadow-xl border border-base-200 overflow-hidden flex-1'
  >
    <div id='proposals' class='card-body p-0 overflow-y-auto'>
      {{#each proposals}}
        <div
          class='group flex flex-col p-6 border-b border-base-200 last:border-none hover:bg-base-200/50 transition-colors'
        >
          <div class='flex justify-between items-start'>
            <div class='flex gap-4'>
              <div class='avatar placeholder'>
                <div
                  class='bg-base-200 text-base-content/50 rounded-full w-12 h-12 flex items-center justify-center'
                >
                  <i class='fas fa-image'></i>
                </div>
              </div>

              <div>
                <h3 class='font-bold text-base-content'>{{name}}</h3>
                <p
                  class='text-sm text-base-content opacity-60 font-medium'
                >{{createdAt}}</p>
              </div>
            </div>

            <div class='flex gap-2'>
              <button
                class='btn btn-primary btn-sm rounded-full px-6'
                data-id='{{id}}'
                data-action='approve'
              >
                Validar
              </button>
              <button
                class='btn btn-ghost bg-base-200 btn-sm rounded-full px-6 hover:bg-base-300'
                data-id='{{id}}'
                data-action='reject'
              >
                Rechazar
              </button>
            </div>
          </div>

          <div class='mt-3'>
            <p class='text-base-content opacity-80 text-sm leading-relaxed'>
              {{description}}
            </p>
          </div>
        </div>
      {{else}}
        <div class='p-6'>
          <p class='text-base-content opacity-60 text-center'>
            No hay propuestas pendientes de validación.
          </p>
        </div>
      {{/each}}
    </div>
  </div>
</div>
{{addLib 'html2pdf'}}
{{addJs '/reports.js'}}
{{addCss '/reports.css'}}

<section class='space-y-6'>
  <header class='flex flex-col gap-2'>
    <p
      class='text-sm uppercase tracking-[0.2em] text-base-content/60'
    >Informes</p>
    <h1 class='text-3xl font-semibold'>Informe de usuarios</h1>
  </header>

  <div class='flex flex-col gap-6 lg:flex-row'>
    <section class='card border border-base-200 bg-base-100 shadow-xl lg:w-2/5'>
      <div class='card-body gap-4'>
        <div class='flex items-center gap-3'>
          <label class='input input-bordered flex w-full items-center gap-2'>
            <i class='fa-solid fa-magnifying-glass text-base-content/60'></i>
            <input
              id='user-search'
              type='text'
              class='grow'
              placeholder='Filtrar por nombre'
            />
          </label>
          <button id='clear-search' class='btn btn-ghost btn-sm' type='button'>
            Limpiar
          </button>
        </div>

        <div id='users-list' class='space-y-3'></div>

        <div class='join' id='pagination'>
          <button class='join-item btn btn-active' data-page='1'>1</button>
        </div>
      </div>
    </section>

    <section
      class='card border border-base-200 bg-base-100 shadow-xl lg:flex-1'
    >
      <div class='card-body gap-6'>
        <div
          class='flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between'
        >
          <div>
            <p
              class='text-sm uppercase tracking-[0.2em] text-base-content/60'
            >Informe</p>
            <h2 class='text-2xl font-semibold' id='report-title'>
              Selecciona un usuario
            </h2>
          </div>
          <button
            id='download-pdf'
            class='btn btn-primary btn-sm'
            type='button'
          >
            Generar PDF
          </button>
        </div>

        <div id='report-sheet' class='report-sheet'>
          <div class='report-header'>
            <div>
              <h3 class='text-xl font-semibold' id='report-user-name'>-</h3>
              <p class='text-sm text-base-content/60' id='report-user-meta'></p>
            </div>
            <div class='report-badge'>SolidarianID</div>
          </div>

          <div class='report-body' id='report-body'>
            <p class='text-base-content/70'>
              Selecciona un usuario para cargar su historial de colaboraciones.
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>
</section>